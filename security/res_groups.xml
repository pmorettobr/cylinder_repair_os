<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_repair_cilindros" model="ir.module.category">
        <field name="name">Reparo Cilindros</field>
        <field name="sequence">20</field>
    </record>

    <!-- Operador — acesso às OS e processos -->
    <record id="group_repair_operator" model="res.groups">
        <field name="name">Operador</field>
        <field name="category_id" ref="module_category_repair_cilindros"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Acesso às Ordens de Serviço, processos e dashboard.</field>
    </record>

    <!-- Inspetor de Qualidade — acesso à tela de CQ -->
    <record id="group_repair_cq" model="res.groups">
        <field name="name">Inspetor de Qualidade</field>
        <field name="category_id" ref="module_category_repair_cilindros"/>
        <field name="implied_ids" eval="[(4, ref('group_repair_operator'))]"/>
        <field name="comment">Acesso à fila de inspeção de qualidade.</field>
    </record>

    <!-- Supervisor — acesso total incluindo CQ e configuração -->
    <record id="group_repair_supervisor" model="res.groups">
        <field name="name">Supervisor</field>
        <field name="category_id" ref="module_category_repair_cilindros"/>
        <field name="implied_ids" eval="[(4, ref('group_repair_cq'))]"/>
        <field name="comment">Acesso completo incluindo CQ, configurações, catálogo e relatórios.</field>
    </record>

</odoo>
