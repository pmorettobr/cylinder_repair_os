<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="paperformat_machine_report_landscape" model="report.paperformat">
    <field name="name">Paisagem A4 Máquinas</field>
    <field name="default" eval="False"/>
    <field name="format">A4</field>
    <field name="orientation">Landscape</field>
    <field name="margin_top">10</field>
    <field name="margin_bottom">10</field>
    <field name="margin_left">7</field>
    <field name="margin_right">7</field>
    <field name="header_line" eval="False"/>
    <field name="header_spacing">3</field>
</record>

<template id="report_machine_schedule_document">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout">
                <div class="page" style="font-size:11px;">

                    <!-- Título e filtros aplicados -->
                    <div style="margin-bottom:8px;">
                        <h3 style="margin:0;color:#4f46e5;">Programação de Produção</h3>
                        <div style="font-size:11px;color:#666;margin-top:3px;">
                            <t t-if="doc.os_id">
                                OS: <strong><t t-esc="doc.os_id.os_number"/></strong> ·
                            </t>
                            <t t-if="doc.machine_id">
                                Máquina: <strong><t t-esc="doc.machine_id.name"/></strong> ·
                            </t>
                            Estados:
                            <strong>
                                <t t-set="state_labels" t-value="[]"/>
                                <t t-if="doc.state_ready">Pronto </t>
                                <t t-if="doc.state_progress">Em Andamento </t>
                                <t t-if="doc.state_paused">Pausado </t>
                                <t t-if="doc.state_done">Concluído </t>
                                <t t-if="doc.state_cancel">Cancelado </t>
                            </strong>
                            <t t-if="doc.use_date_filter and doc.date_from and doc.date_to">
                                · Período: <strong>
                                    <t t-esc="doc.date_from.strftime('%d/%m/%Y')"/>
                                </strong> até <strong>
                                    <t t-esc="doc.date_to.strftime('%d/%m/%Y')"/>
                                </strong>
                            </t>
                        </div>
                    </div>

                    <hr style="margin:6px 0;"/>

                    <!-- Agrupa processos por OS — dados pré-calculados pelo AbstractModel -->
                    <t t-foreach="os_groups" t-as="og">

                        <div style="margin:10px 0 4px;padding:4px 8px;background:#eff6ff;border-left:4px solid #4f46e5;border-radius:3px;">
                            <strong style="font-size:12px;">
                                OS <t t-esc="og['os_number']"/>
                            </strong>
                            <t t-if="og['partner']">
                                <span style="color:#555;margin-left:12px;">
                                    Cliente: <strong><t t-esc="og['partner']"/></strong>
                                </span>
                            </t>
                            <t t-if="og['product']">
                                <span style="color:#555;margin-left:12px;">
                                    Produto: <t t-esc="og['product']"/>
                                </span>
                            </t>
                        </div>

                        <table style="width:100%;border-collapse:collapse;font-size:11px;margin-bottom:8px;">
                            <thead>
                                <tr style="background:#f3f4f6;border-bottom:2px solid #d1d5db;">
                                    <th style="width:4%;padding:4px 6px;text-align:center;border:1px solid #d1d5db;">Seq.</th>
                                    <th style="width:12%;padding:4px 6px;border:1px solid #d1d5db;">Máquina</th>
                                    <th style="width:18%;padding:4px 6px;border:1px solid #d1d5db;">Operação</th>
                                    <th style="width:7%;padding:4px 6px;text-align:center;border:1px solid #d1d5db;">Previsto</th>
                                    <th style="width:10%;padding:4px 6px;border:1px solid #d1d5db;">Operador</th>
                                    <th style="width:8%;padding:4px 6px;text-align:center;border:1px solid #d1d5db;">Situação</th>
                                    <th style="padding:4px 6px;border:1px solid #d1d5db;">OBS</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="og['processes']" t-as="proc">
                                    <tr t-attf-style="background:#{proc['state'] == 'done' and '#f0fdf4' or proc['state'] == 'progress' and '#fffbeb' or proc['state'] == 'paused' and '#eff6ff' or proc['state'] == 'pending_cq' and '#fef3c7' or '#fff'};">
                                        <td style="padding:5px 6px;text-align:center;border:1px solid #e5e7eb;">
                                            <t t-esc="proc['sequence']"/>
                                        </td>
                                        <td style="padding:5px 6px;border:1px solid #e5e7eb;">
                                            <t t-esc="proc['machine']"/>
                                        </td>
                                        <td style="padding:5px 6px;border:1px solid #e5e7eb;">
                                            <t t-esc="proc['name']"/>
                                        </td>
                                        <td style="padding:5px 6px;text-align:center;border:1px solid #e5e7eb;">
                                            <t t-esc="proc['duration_display'] if proc['duration_planned'] else '—'"/>
                                        </td>
                                        <td style="padding:5px 6px;border:1px solid #e5e7eb;">
                                            <t t-esc="proc['operator']"/>
                                        </td>
                                        <td style="padding:5px 6px;text-align:center;border:1px solid #e5e7eb;font-size:10px;">
                                            <t t-esc="proc['state_label']"/>
                                        </td>
                                        <td style="padding:5px 6px;border:1px solid #e5e7eb;"> </td>
                                    </tr>
                                    <t t-if="proc['has_deviation'] and proc['deviation_notes']">
                                        <tr style="background:#fff8f0;">
                                            <td colspan="7" style="padding:3px 10px;border:1px solid #e5e7eb;color:#b45309;font-size:10px;">
                                                ⚠ Desvio: <t t-esc="proc['deviation_notes']"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>

                    </t>

                    <t t-if="not os_groups">
                        <div style="text-align:center;color:#9ca3af;margin-top:30px;font-size:13px;">
                            Nenhum processo encontrado para os filtros selecionados.
                        </div>
                    </t>

                </div>
            </t>
        </t>
    </t>
</template>

<record id="action_report_machine_schedule" model="ir.actions.report">
    <field name="name">Programação por Máquina</field>
    <field name="model">repair.machine.report.wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">cylinder_repair_os.report_machine_schedule_document</field>
    <field name="report_file">cylinder_repair_os.report_machine_schedule_document</field>
    <field name="paperformat_id" ref="paperformat_machine_report_landscape"/>
</record>

</odoo>
