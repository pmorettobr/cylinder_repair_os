<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="report_os_document">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout">
        <div class="page">
                    <style>
                        .header { display: none !important; }
                        .footer { display: none !important; }
                        .o_company_logo { display: none !important; }
                        ul { list-style: none; margin: 0; padding: 0; }
                    </style>

            <!-- Cabeçalho da OS -->
            <div class="row mb-3">
                <div class="col-12">
                    <h3 style="margin:0">
                        Ordem de Serviço — <span t-field="doc.os_number"/>
                        <small class="ms-2 text-muted">
                            [<t t-esc="dict(doc._fields['order_type'].selection).get(doc.order_type, '')"/>]
                        </small>
                    </h3>
                    <table style="margin-top:8px;font-size:12px;width:100%">
                        <tr>
                            <td style="width:120px;color:#666">Cliente:</td>
                            <td><strong><span t-field="doc.partner_id"/></strong></td>
                            <td style="width:120px;color:#666">Produto / Cilindro:</td>
                            <td><t t-esc="doc.cylinder_id.name or '—'"/></td>
                        </tr>
                        <tr>
                            <td style="color:#666">Prazo:</td>
                            <td>
                                <t t-if="doc.deadline_date">
                                    <t t-esc="doc.deadline_date.strftime('%d/%m/%Y')"/>
                                </t>
                                <t t-else="">—</t>
                            </td>
                            <td></td><td></td>
                        </tr>
                        <tr>
                            <td style="color:#666">Responsável:</td>
                            <td><t t-esc="doc.responsible_id.name if doc.responsible_id else '—'"/></td>
                            <td style="color:#666">Estado:</td>
                            <td><t t-esc="dict(doc._fields['os_state'].selection).get(doc.os_state, '')"/></td>
                        </tr>
                    </table>
                </div>

            </div>

            <hr style="margin:6px 0;border-color:#d1d5db;"/>

            <!-- Tabela única com agrupamento por componente -->
            <table style="width:100%;border-collapse:collapse;font-size:10.5px;">
                <colgroup>
                    <col style="width:28%"/>
                    <col style="width:16%"/>
                    <col style="width:13%"/>
                    <col style="width:15%"/>
                    <col style="width:10%"/>
                </colgroup>
                <thead>
                    <tr style="background:#f3f4f6;border-bottom:1.5px solid #9ca3af;">
                        <th style="padding:4px 6px;text-align:left;font-weight:700;">Operação</th>
                        <th style="padding:4px 6px;text-align:left;font-weight:700;">Máquina</th>
                        <th style="padding:4px 6px;text-align:left;font-weight:700;">Status</th>
                        <th style="padding:4px 6px;text-align:left;font-weight:700;">Data Início</th>
                        <th style="padding:4px 6px;text-align:left;font-weight:700;">Tempo</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="state_map" t-value="{'ready':'Pronto','progress':'Em Andamento','paused':'Pausado','pending_cq':'Aguardando CQ','done':'Concluído','cancel':'Cancelado'}"/>
                    <t t-foreach="doc.process_ids.mapped('component_type_id')" t-as="comp">
                        <t t-set="procs" t-value="doc.process_ids.filtered(lambda p: p.component_type_id == comp).sorted('sequence')"/>
                        <t t-if="procs">
                            <!-- Linha de cabeçalho do componente -->
                            <tr style="background:#eff6ff;border-top:1px solid #bfdbfe;border-bottom:1px solid #bfdbfe;">
                                <td colspan="5" style="padding:3px 6px;font-weight:700;font-size:10.5px;color:#1e40af;border-left:3px solid #4f46e5;">
                                    <t t-esc="comp.name if comp else 'Sem Componente'"/>
                                </td>
                            </tr>
                            <!-- Processos do componente -->
                            <t t-foreach="procs" t-as="proc">
                                <tr t-attf-style="border-bottom:1px solid #e5e7eb;background:#{proc.state == 'done' and '#f0fdf4' or proc.state == 'progress' and '#fffbeb' or proc.state == 'pending_cq' and '#fef3c7' or '#fff'};">
                                    <td style="padding:4px 6px;"><t t-esc="proc.name"/></td>
                                    <td style="padding:4px 6px;"><t t-esc="proc.machine_id.name if proc.machine_id else '—'"/></td>
                                    <td style="padding:4px 6px;"><t t-esc="state_map.get(proc.state, proc.state)"/></td>
                                    <td style="padding:4px 6px;">
                                        <t t-if="proc.date_start_orig"><t t-esc="proc.date_start_orig.strftime('%d/%m %H:%M')"/></t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td style="padding:4px 6px;"><t t-esc="proc.duration_display"/></td>
                                </tr>
                                <t t-if="proc.has_deviation and proc.deviation_notes">
                                    <tr style="background:#fff8f0;border-bottom:1px solid #e5e7eb;">
                                        <td colspan="5" style="padding:3px 6px 3px 16px;color:#b45309;font-size:10px;">
                                            ⚠ Desvio: <t t-esc="proc.deviation_notes"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </t>
                    </t>
                </tbody>
            </table>

        </div>
            </t>
        </t>
    </t>
</template>

<record id="action_report_os" model="ir.actions.report">
    <field name="name">Ordem de Serviço</field>
    <field name="model">repair.order</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">cylinder_repair_os.report_os_document</field>
    <field name="report_file">cylinder_repair_os.report_os_document</field>
    <field name="binding_model_id" ref="repair.model_repair_order"/>
    <field name="binding_type">report</field>
</record>

</odoo>
