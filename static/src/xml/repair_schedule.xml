<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="cylinder_repair_os.RepairSchedule" owl="1">
    <div class="o_action o_repair_schedule_action" style="height:100%;display:flex;flex-direction:column;">

        <!-- Loading -->
        <t t-if="state.loading">
            <div class="text-center p-5 text-muted">
                <i class="fa fa-spinner fa-spin fa-2x"/>
                <div class="mt-2">Carregando...</div>
            </div>
        </t>

        <t t-elif="!repairId">
            <div class="text-center p-5 text-danger">OS não identificada.</div>
        </t>

        <t t-else="">

            <!-- ── Cabeçalho ── -->
            <div class="o_repair_schedule_header d-flex align-items-center gap-3 px-3 py-2 border-bottom bg-white flex-shrink-0" style="flex-wrap:wrap;">

                <!-- Voltar à OS -->
                <button class="btn btn-sm btn-outline-secondary" t-on-click="goBackToOs">
                    <i class="fa fa-arrow-left me-1"/> Voltar à OS
                </button>

                <!-- Adicionar Processos -->
                <button class="btn btn-sm btn-outline-primary" t-on-click="openProcessLoader">
                    <i class="fa fa-plus me-1"/> Adicionar Processos
                </button>

                <div class="vr"/>

                <!-- Info da OS -->
                <span class="fw-bold">OS: <t t-esc="state.repairInfo.os_number or '—'"/></span>
                <span class="text-muted">
                    <t t-esc="state.repairInfo.partner_id ? state.repairInfo.partner_id[1] : ''"/>
                </span>
                <t t-if="state.repairInfo.product_name">
                    <span class="text-muted">
                        · <t t-esc="state.repairInfo.product_name"/>
                    </span>
                </t>
                <t t-if="state.repairInfo.deadline_date">
                    <span class="text-muted">
                        · Prazo: <t t-esc="fmtDate(state.repairInfo.deadline_date)"/>
                    </span>
                </t>

                <span t-att-class="'badge ms-auto ' + osStateBadge(state.repairInfo.os_state)"
                      t-esc="osStateLabel(state.repairInfo.os_state)"/>
            </div>

            <!-- ── Grid ── -->
            <div class="o_repair_schedule_body flex-grow-1 overflow-auto p-3">

                <t t-if="grouped.length === 0">
                    <div class="text-center text-muted py-5">
                        <i class="fa fa-inbox fa-3x mb-3 d-block"/>
                        Nenhum processo. Clique em <strong>Adicionar Processos</strong>.
                    </div>
                </t>

                <t t-foreach="grouped" t-as="group" t-key="group.id">

                    <!-- Cabeçalho do componente -->
                    <div class="d-flex align-items-center gap-2 px-2 py-1 mb-1 rounded"
                         style="background:#e8edf2;border-left:4px solid #4f46e5;">
                        <span style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:#334155;">
                            <t t-esc="group.name"/>
                        </span>
                        <span class="badge bg-secondary" t-esc="group.records.length + ' processo(s)'"/>
                        <t t-if="group.prog > 0">
                            <span class="badge text-bg-warning"><t t-esc="group.prog"/> em andamento</span>
                        </t>
                        <t t-if="group.done === group.records.length and group.records.length > 0">
                            <span class="badge bg-success">✓ Concluído</span>
                        </t>
                    </div>

                    <!-- Tabela do componente -->
                    <table class="table table-sm table-hover mb-3">
                        <thead class="table-light small text-muted">
                            <tr>
                                <th style="width:40px">Seq.</th>
                                <th>Operação</th>
                                <th style="width:130px">Máquina</th>
                                <th style="width:100px">Operador</th>
                                <th style="width:110px">Data Prog.</th>
                                <th style="width:130px">Dt. Início</th>
                                <th style="width:85px">Tempo</th>
                                <th style="width:110px">Situação</th>
                                <th style="width:30px">⚠</th>
                                <th style="width:220px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="group.records" t-as="rec" t-key="rec.id">
                                <tr t-att-class="'o_repair_proc_row ' + rowCls(rec.state)">

                                    <td class="text-center text-muted small"><t t-esc="rec.sequence"/></td>

                                    <td class="fw-medium"><t t-esc="rec.name"/></td>

                                    <td class="small"><t t-esc="rec.machine_id ? rec.machine_id[1] : '—'"/></td>

                                    <td class="small text-muted"><t t-esc="rec.operator_id ? rec.operator_id[1] : '—'"/></td>

                                    <!-- Data Prog. editável inline -->
                                    <td>
                                        <t t-if="state.editDateId === rec.id">
                                            <input type="date"
                                                   class="form-control form-control-sm"
                                                   style="width:120px;"
                                                   t-att-value="rec.date_planned or ''"
                                                   t-on-change="(ev) => this.saveDate(rec.id, ev)"
                                                   t-on-blur="() => this.cancelEditDate()"/>
                                        </t>
                                        <t t-else="">
                                            <span t-on-click="() => this.startEditDate(rec.id)"
                                                  style="cursor:pointer;"
                                                  t-att-class="!rec.date_planned ? 'text-muted fst-italic small' : 'small'">
                                                <t t-if="rec.date_planned">
                                                    <t t-esc="fmtDate(rec.date_planned)"/>
                                                </t>
                                                <t t-else="">definir</t>
                                            </span>
                                        </t>
                                    </td>

                                    <td class="small text-muted"><t t-esc="fmtDatetime(rec.date_start_orig)"/></td>

                                    <td>
                                        <span class="o_repair_timer small"
                                              t-att-class="rec.state === 'progress' ? 'o_repair_timer_running fw-bold' : 'text-muted'"
                                              t-att-data-start="rec.date_start or ''"
                                              t-att-data-acc="rec.duration_acc or 0">
                                            <t t-esc="rec.duration_display or '00:00:00'"/>
                                        </span>
                                    </td>

                                    <td>
                                        <span t-att-class="'badge ' + stateBadge(rec.state)"
                                              t-esc="stateLabel(rec.state)"/>
                                    </td>

                                    <!-- Desvio -->
                                    <td class="text-center">
                                        <t t-if="rec.has_deviation">
                                            <span class="text-warning"
                                                  style="cursor:pointer;font-size:14px;"
                                                  t-att-title="rec.deviation_notes or 'Desvio registrado'"
                                                  t-on-click="() => this.onDeviation(rec.id)">⚠</span>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted"
                                                  style="cursor:pointer;font-size:14px;"
                                                  title="Sem desvio"
                                                  t-on-click="() => this.onDeviation(rec.id)">○</span>
                                        </t>
                                    </td>

                                    <!-- Botões de ação -->
                                    <td>
                                        <t t-if="state.loadingId === rec.id">
                                            <i class="fa fa-spinner fa-spin text-muted"/>
                                        </t>
                                        <t t-else="">
                                            <t t-if="rec.state === 'ready' or rec.state === 'paused'">
                                                <button class="btn btn-sm btn-success me-1"
                                                        t-on-click="() => this.onStart(rec.id)">
                                                    ▶ Iniciar
                                                </button>
                                            </t>
                                            <t t-if="rec.state === 'progress'">
                                                <button class="btn btn-sm btn-warning me-1"
                                                        t-on-click="() => this.onPause(rec.id)">
                                                    ⏸ Pausar
                                                </button>
                                            </t>
                                            <t t-if="rec.state === 'progress' or rec.state === 'paused'">
                                                <button class="btn btn-sm btn-primary me-1"
                                                        t-on-click="() => this.onFinish(rec.id)">
                                                    ✓ Concluir
                                                </button>
                                            </t>
                                            <t t-if="rec.state === 'ready' or rec.state === 'paused'">
                                                <button class="btn btn-sm btn-link text-danger p-0 ms-1"
                                                        title="Cancelar"
                                                        t-on-click="() => this.onCancel(rec.id)">
                                                    <i class="fa fa-ban"/>
                                                </button>
                                            </t>
                                        </t>
                                    </td>

                                </tr>
                            </t>
                        </tbody>
                    </table>

                </t>
            </div>
        </t>
    </div>
</t>

</templates>
