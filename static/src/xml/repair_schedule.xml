<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="cylinder_repair_os.RepairSchedule" owl="1">
<div class="o_action o_repair_schedule_action">

    <t t-if="state.loading">
        <div class="text-center p-5 text-muted">
            <i class="fa fa-spinner fa-spin fa-2x"/>
            <div class="mt-2">Carregando...</div>
        </div>
    </t>

    <t t-elif="!repairId">
        <div class="text-center p-5 text-danger">OS não identificada.</div>
    </t>

    <t t-else="">

        <!-- CABEÇALHO -->
        <div class="o_repair_schedule_header bg-white border-bottom">

            <!-- Linha 1: botões + info OS + progresso geral -->
            <div class="d-flex align-items-center gap-3 px-3 py-2 flex-wrap">

                <button class="btn btn-outline-secondary" t-on-click="goBackToOs">
                    <i class="fa fa-arrow-left me-1"/>Voltar à OS
                </button>

                <button class="btn btn-outline-primary" t-on-click="openProcessLoader">
                    <i class="fa fa-plus me-1"/>Adicionar Processos
                </button>

                <div class="vr"/>

                <!-- OS + Cliente -->
                <span class="fw-bold" style="font-size:1rem;">
                    OS <t t-esc="state.repairInfo.os_number or '—'"/>
                </span>
                <t t-if="state.repairInfo.partner_id">
                    <span class="text-muted">|</span>
                    <span><t t-esc="state.repairInfo.partner_id[1]"/></span>
                </t>

                <div class="vr"/>

                <span class="text-muted" style="font-size:0.9rem;white-space:nowrap;">
                    <t t-esc="totalDone"/>/<t t-esc="state.processes.length"/> concluídos
                </span>
                <div style="width:160px;height:8px;background:#e5e7eb;border-radius:4px;overflow:hidden;flex-shrink:0;">
                    <div t-att-style="globalBarStyle()"/>
                </div>
                <span class="fw-bold" style="font-size:0.9rem;color:#4f46e5;white-space:nowrap;">
                    <t t-esc="totalProgress"/>%
                </span>

            </div>
        </div>

        <!-- GRID -->
        <div class="o_repair_schedule_body">

            <t t-if="grouped.length === 0">
                <div class="text-center text-muted py-5">
                    <i class="fa fa-inbox fa-3x mb-3 d-block"/>
                    Nenhum processo. Clique em <strong>Adicionar Processos</strong>.
                </div>
            </t>

            <t t-foreach="grouped" t-as="group" t-key="group.id">

                <!-- Cabeçalho do componente -->
                <div class="o_repair_group_header mt-3 rounded overflow-hidden"
                     t-att-style="groupHeaderStyle(group_index)">

                    <div class="d-flex align-items-center gap-2 px-3 py-2"
                         style="cursor:pointer;"
                         t-on-click="() => this.toggleGroup(group.id)">
                        <span style="font-size:12px;font-weight:600;color:#374151;">
                            <t t-if="state.collapsed[group.id]">▶</t>
                            <t t-else="">▼</t>
                        </span>
                        <span style="font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:.5px;color:#374151;">
                            <t t-esc="group.name"/>
                        </span>
                        <!-- done/total -->
                        <span style="font-size:12px;color:#374151;font-weight:600;">
                            <t t-esc="group.done"/>/<t t-esc="group.records.length"/> concluídos
                        </span>
                        <t t-if="group.prog > 0">
                            <span class="badge text-bg-warning" style="font-size:11px;">
                                <t t-esc="group.prog"/> em andamento
                            </span>
                        </t>
                        <t t-if="group.done === group.records.length and group.records.length > 0">
                            <span class="badge bg-success" style="font-size:11px;">✓ Concluído</span>
                        </t>
                        <span class="ms-auto fw-bold" style="font-size:11px;color:#374151;">
                            <t t-esc="groupProgress(group)"/>%
                        </span>
                    </div>

                </div>

                <t t-if="!state.collapsed[group.id]">
                    <div class="o_repair_table_wrap">
                        <table class="table table-sm table-hover mb-0 o_repair_proc_table">
                            <colgroup>
                                <col style="width:28px"/>
                                <col style="width:42px"/>
                                <col/>
                                <col style="width:120px"/>
                                <col style="width:120px"/>
                                <col style="width:100px"/>
                                <col style="width:110px"/>
                                <col style="width:75px"/>
                                <col style="width:85px"/>
                                <col style="width:95px"/>
                                <col style="width:65px"/>
                                <col style="width:52px"/>
                                <col style="width:200px"/>
                                <col style="width:64px"/>
                            </colgroup>
                            <thead class="table-light">
                                <tr>
                                    <th></th>
                                    <th class="text-center">Seq.</th>
                                    <th>Operação</th>
                                    <th>Máquina</th>
                                    <th>Operador</th>
                                    <th>Data Prog.</th>
                                    <th>Dt. Início</th>
                                    <th>Previsto</th>
                                    <th>Tempo</th>
                                    <th>Situação</th>
                                    <th>Desvio</th>
                                    <th class="text-center">CQ</th>
                                    <th></th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="group.records" t-as="rec" t-key="rec.id">
                                    <tr t-att-class="rowCls(rec.state, state.dragOverId === rec.id)"
                                        draggable="true"
                                        t-on-dragstart="(ev) => this.onDragStart(ev, rec.id)"
                                        t-on-dragover="(ev) => this.onDragOver(ev, rec.id)"
                                        t-on-dragleave="(ev) => this.onDragLeave(ev)"
                                        t-on-drop="(ev) => this.onDrop(ev, group.id, rec.id)"
                                        t-on-dragend="() => this.onDragEnd()">

                                        <td class="text-center text-muted o_repair_drag_handle">⠿</td>

                                        <td class="text-center text-muted">
                                            <t t-esc="rec.sequence"/>
                                        </td>

                                        <td><t t-esc="rec.name"/></td>

                                        <td class="text-muted">
                                            <t t-esc="rec.machine_id ? rec.machine_id[1] : '—'"/>
                                        </td>

                                        <!-- Operador editável -->
                                        <td>
                                            <t t-if="state.editOperatorId === rec.id">
                                                <select class="form-select form-select-sm"
                                                        t-on-change="(ev) => this.saveOperator(rec.id, ev)"
                                                        t-on-blur="() => this.cancelEditOperator()">
                                                    <option value="">— nenhum —</option>
                                                    <t t-foreach="state.operatorOptions" t-as="op" t-key="op.id">
                                                        <option t-att-value="op.id"
                                                                t-att-selected="rec.operator_id and rec.operator_id[0] === op.id ? 'selected' : ''">
                                                            <t t-esc="op.name"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </t>
                                            <t t-else="">
                                                <span style="cursor:pointer;"
                                                      t-att-class="!rec.operator_id ? 'text-muted fst-italic' : ''"
                                                      t-on-click="() => this.startEditOperator(rec)">
                                                    <t t-if="rec.operator_id"><t t-esc="rec.operator_id[1]"/></t>
                                                    <t t-else="">definir</t>
                                                </span>
                                            </t>
                                        </td>

                                        <!-- Data Prog. -->
                                        <td>
                                            <t t-if="state.editDateId === rec.id">
                                                <input type="date" class="form-control form-control-sm"
                                                       t-att-value="rec.date_planned or ''"
                                                       t-on-change="(ev) => this.saveDate(rec.id, ev)"
                                                       t-on-blur="() => this.cancelEditDate()"/>
                                            </t>
                                            <t t-else="">
                                                <span style="cursor:pointer;"
                                                      t-att-class="!rec.date_planned ? 'text-muted fst-italic' : ''"
                                                      t-on-click="() => this.startEditDate(rec.id)">
                                                    <t t-if="rec.date_planned"><t t-esc="fmtDate(rec.date_planned)"/></t>
                                                    <t t-else="">definir</t>
                                                </span>
                                            </t>
                                        </td>

                                        <!-- Dt. Início -->
                                        <td class="text-muted">
                                            <t t-esc="fmtDatetime(rec.date_start_orig)"/>
                                        </td>

                                        <!-- Tempo Previsto — timepicker -->
                                        <td>
                                            <t t-if="state.editPlannedId === rec.id">
                                                <input type="time" class="form-control form-control-sm"
                                                       t-att-value="_min2hhmm(rec.duration_planned)"
                                                       t-on-change="(ev) => this.savePlanned(rec.id, ev)"
                                                       t-on-blur="() => this.cancelEditPlanned()"/>
                                            </t>
                                            <t t-else="">
                                                <span style="cursor:pointer;"
                                                      t-att-class="!rec.duration_planned ? 'text-muted fst-italic' : ''"
                                                      t-on-click="() => this.startEditPlanned(rec.id)">
                                                    <t t-esc="_min2hhmm(rec.duration_planned)"/>
                                                </span>
                                            </t>
                                        </td>

                                        <!-- Tempo real -->
                                        <td>
                                            <span class="o_repair_timer"
                                                  t-att-class="rec.state === 'progress' ? 'o_repair_timer_running fw-bold text-warning' : 'text-muted'"
                                                  t-att-data-start="rec.state === 'progress' ? (rec.date_start or '') : ''"
                                                  t-att-data-acc="(rec.duration_acc or 0) * 60">
                                                <t t-esc="timerDisplay(rec)"/>
                                            </span>
                                        </td>

                                        <!-- Situação -->
                                        <td>
                                            <span t-att-class="'badge ' + stateBadge(rec.state)"
                                                  style="font-size:12px;"
                                                  t-esc="stateLabel(rec.state)"/>
                                        </td>

                                        <!-- Desvio -->
                                        <td class="text-center">
                                            <t t-if="rec.has_deviation">
                                                <span class="text-warning"
                                                      style="cursor:pointer;"
                                                      t-att-title="rec.deviation_notes or 'Desvio registrado'"
                                                      t-on-click="() => this.onDeviation(rec.id)">
                                                    <i class="fa fa-exclamation-triangle fa-lg"/>
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="text-muted"
                                                      style="cursor:pointer;"
                                                      title="Sem desvio"
                                                      t-on-click="() => this.onDeviation(rec.id)">
                                                    <i class="fa fa-circle-o fa-lg"/>
                                                </span>
                                            </t>
                                        </td>

                                        <!-- CQ -->
                                        <td class="text-center">
                                            <t t-set="cq" t-value="cqIcon(rec)"/>
                                            <span t-att-class="cq.cls"
                                                  style="cursor:pointer;font-size:16px;"
                                                  t-att-title="cq.title + (rec.cq_rejection_count ? ' (' + rec.cq_rejection_count + 'x reprovado)' : '')">
                                                <i t-att-class="'fa ' + cq.icon"/>
                                            </span>
                                        </td>

                                        <!-- Botões principais -->
                                        <td class="o_repair_proc_actions">
                                            <t t-if="state.loadingId === rec.id">
                                                <i class="fa fa-spinner fa-spin text-muted"/>
                                            </t>
                                            <t t-else="">
                                                <t t-if="rec.state === 'ready' or rec.state === 'paused'">
                                                    <button class="o_repair_action_btn o_repair_btn_start"
                                                            t-on-click="() => this.onStart(rec.id)">Iniciar</button>
                                                </t>
                                                <t t-if="rec.state === 'progress'">
                                                    <button class="o_repair_action_btn o_repair_btn_pause"
                                                            t-on-click="() => this.onPause(rec.id)">Pausar</button>
                                                </t>
                                                <t t-if="rec.state === 'progress' or rec.state === 'paused'">
                                                    <button class="o_repair_action_btn o_repair_btn_finish"
                                                            t-on-click="() => this.onFinish(rec.id)">Concluir</button>
                                                </t>
                                            </t>
                                        </td>

                                        <!-- Cancelar + Excluir -->
                                        <td>
                                            <div class="d-flex gap-2 align-items-center">
                                                <t t-if="rec.state === 'ready' or rec.state === 'paused'">
                                                    <button class="btn btn-link text-danger p-0"
                                                            title="Cancelar processo"
                                                            t-on-click="() => this.onCancel(rec.id)">
                                                        <i class="fa fa-times-circle fa-lg"/>
                                                    </button>
                                                </t>
                                                <t t-if="rec.state === 'ready' or rec.state === 'cancel'">
                                                    <button class="btn btn-link text-danger p-0"
                                                            title="Excluir processo"
                                                            t-on-click="() => this.onDelete(rec.id)">
                                                        <i class="fa fa-trash fa-lg"/>
                                                    </button>
                                                </t>
                                            </div>
                                        </td>

                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>

            </t>
        </div>

    </t>
</div>
</t>

</templates>
