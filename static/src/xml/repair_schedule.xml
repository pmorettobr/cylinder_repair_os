<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="cylinder_repair_os.RepairSchedule" owl="1">
<div class="o_action o_repair_schedule_action">

    <t t-if="state.loading">
        <div class="text-center p-5 text-muted">
            <i class="fa fa-spinner fa-spin fa-2x"/>
            <div class="mt-2">Carregando...</div>
        </div>
    </t>

    <t t-elif="!repairId">
        <div class="text-center p-5 text-danger">OS não identificada.</div>
    </t>

    <t t-else="">

        <!-- CABEÇALHO -->
        <div class="o_repair_schedule_header">

            <!-- Smartbuttons -->
            <div class="oe_button_box" name="button_box">

                <button class="oe_stat_button" type="button" t-on-click="goBackToOs">
                    <i class="fa fa-arrow-left o_button_icon"/>
                    <div class="o_stat_info">
                        <span class="o_stat_text">Voltar</span>
                        <span class="o_stat_text">à OS</span>
                    </div>
                </button>

                <button class="oe_stat_button" type="button" t-on-click="openProcessLoader">
                    <i class="fa fa-plus o_button_icon"/>
                    <div class="o_stat_info">
                        <span class="o_stat_text">Adicionar</span>
                        <span class="o_stat_text">Processos</span>
                    </div>
                </button>

                <div class="oe_stat_button o_repair_stat_info" style="cursor:default;">
                    <i class="fa fa-list-ul o_button_icon"/>
                    <div class="o_stat_info">
                        <span class="o_stat_value"><t t-esc="state.processes.length"/></span>
                        <span class="o_stat_text">Processos</span>
                    </div>
                </div>

            </div>

            <!-- Info da OS -->
            <div class="o_repair_prog_os_info mt-2 px-3 py-2 border-bottom">
                <span class="fw-bold fs-5 me-2">
                    <t t-esc="state.repairInfo.os_number or '—'"/>
                </span>
                <span t-att-class="'badge me-3 ' + osStateBadge(state.repairInfo.os_state)"
                      t-esc="osStateLabel(state.repairInfo.os_state)"/>
                <span class="text-muted me-1">Cliente:</span>
                <span class="me-3 fw-medium">
                    <t t-esc="state.repairInfo.partner_id ? state.repairInfo.partner_id[1] : '—'"/>
                </span>
                <t t-if="state.repairInfo.product_name">
                    <span class="text-muted me-1">Produto:</span>
                    <span class="me-3"><t t-esc="state.repairInfo.product_name"/></span>
                </t>
                <t t-if="state.repairInfo.deadline_date">
                    <span class="text-muted me-1">Prazo:</span>
                    <span><t t-esc="fmtDate(state.repairInfo.deadline_date)"/></span>
                </t>
            </div>
        </div>

        <!-- GRID -->
        <div class="o_repair_schedule_body">

            <t t-if="grouped.length === 0">
                <div class="text-center text-muted py-5">
                    <i class="fa fa-inbox fa-3x mb-3 d-block"/>
                    Nenhum processo. Clique em <strong>Adicionar Processos</strong>.
                </div>
            </t>

            <t t-foreach="grouped" t-as="group" t-key="group.id">

                <!-- Cabeçalho do componente (colapsável) -->
                <div class="o_repair_group_header d-flex align-items-center gap-2 px-3 py-2 mt-2"
                     t-on-click="() => this.toggleGroup(group.id)"
                     style="cursor:pointer;background:#e8edf2;border-left:4px solid #4f46e5;border-radius:4px;">
                    <span style="font-size:11px;font-weight:700;color:#334155;">
                        <t t-if="state.collapsed[group.id]">▶</t>
                        <t t-else="">▼</t>
                    </span>
                    <span style="font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:#334155;">
                        <t t-esc="group.name"/>
                    </span>
                    <span class="badge bg-secondary">
                        <t t-esc="group.records.length"/> processo(s)
                    </span>
                    <t t-if="group.prog > 0">
                        <span class="badge text-bg-warning">
                            <t t-esc="group.prog"/> em andamento
                        </span>
                    </t>
                    <t t-if="group.done === group.records.length and group.records.length > 0">
                        <span class="badge bg-success">✓ Concluído</span>
                    </t>
                </div>

                <!-- Tabela do grupo -->
                <t t-if="!state.collapsed[group.id]">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 o_repair_proc_table">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:28px"></th>
                                    <th style="width:40px">Seq.</th>
                                    <th>Operação</th>
                                    <th style="width:130px">Máquina</th>
                                    <th style="width:140px">Operador</th>
                                    <th style="width:105px">Data Prog.</th>
                                    <th style="width:120px">Dt. Início</th>
                                    <th style="width:85px">Tempo</th>
                                    <th style="width:100px">Situação</th>
                                    <th style="width:30px">⚠</th>
                                    <th style="width:235px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="group.records" t-as="rec" t-key="rec.id">
                                    <tr t-att-class="rowCls(rec.state, state.dragOverId === rec.id)"
                                        draggable="true"
                                        t-on-dragstart="(ev) => this.onDragStart(ev, rec.id)"
                                        t-on-dragover="(ev) => this.onDragOver(ev, rec.id)"
                                        t-on-dragleave="(ev) => this.onDragLeave(ev)"
                                        t-on-drop="(ev) => this.onDrop(ev, group.id, rec.id)"
                                        t-on-dragend="() => this.onDragEnd()">

                                        <!-- Handle arrastar -->
                                        <td class="text-center o_repair_drag_handle text-muted"
                                            style="cursor:grab;font-size:14px;">⠿</td>

                                        <!-- Seq -->
                                        <td class="text-center text-muted small">
                                            <t t-esc="rec.sequence"/>
                                        </td>

                                        <!-- Operação -->
                                        <td class="fw-medium"><t t-esc="rec.name"/></td>

                                        <!-- Máquina -->
                                        <td class="small">
                                            <t t-esc="rec.machine_id ? rec.machine_id[1] : '—'"/>
                                        </td>

                                        <!-- Operador editável -->
                                        <td>
                                            <t t-if="state.editOperatorId === rec.id">
                                                <select class="form-select form-select-sm"
                                                        style="min-width:120px;"
                                                        t-on-change="(ev) => this.saveOperator(rec.id, ev)"
                                                        t-on-blur="() => this.cancelEditOperator()">
                                                    <option value="">— nenhum —</option>
                                                    <t t-foreach="state.operatorOptions" t-as="op" t-key="op.id">
                                                        <option t-att-value="op.id"
                                                                t-att-selected="rec.operator_id and rec.operator_id[0] === op.id">
                                                            <t t-esc="op.name"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </t>
                                            <t t-else="">
                                                <span class="small"
                                                      style="cursor:pointer;"
                                                      t-att-class="!rec.operator_id ? 'text-muted fst-italic' : ''"
                                                      t-on-click="() => this.startEditOperator(rec)">
                                                    <t t-if="rec.operator_id">
                                                        <t t-esc="rec.operator_id[1]"/>
                                                    </t>
                                                    <t t-else="">definir</t>
                                                </span>
                                            </t>
                                        </td>

                                        <!-- Data Prog. editável -->
                                        <td>
                                            <t t-if="state.editDateId === rec.id">
                                                <input type="date"
                                                       class="form-control form-control-sm"
                                                       style="width:110px;"
                                                       t-att-value="rec.date_planned or ''"
                                                       t-on-change="(ev) => this.saveDate(rec.id, ev)"
                                                       t-on-blur="() => this.cancelEditDate()"/>
                                            </t>
                                            <t t-else="">
                                                <span class="small"
                                                      style="cursor:pointer;"
                                                      t-att-class="!rec.date_planned ? 'text-muted fst-italic' : ''"
                                                      t-on-click="() => this.startEditDate(rec.id)">
                                                    <t t-if="rec.date_planned">
                                                        <t t-esc="fmtDate(rec.date_planned)"/>
                                                    </t>
                                                    <t t-else="">definir</t>
                                                </span>
                                            </t>
                                        </td>

                                        <!-- Dt. Início -->
                                        <td class="small text-muted">
                                            <t t-esc="fmtDatetime(rec.date_start_orig)"/>
                                        </td>

                                        <!-- Tempo (cronômetro) -->
                                        <td>
                                            <span class="o_repair_timer small"
                                                  t-att-class="rec.state === 'progress' ? 'o_repair_timer_running fw-bold' : 'text-muted'"
                                                  t-att-data-start="rec.date_start or ''"
                                                  t-att-data-acc="rec.duration_acc or 0">
                                                <t t-esc="rec.duration_display or '00:00:00'"/>
                                            </span>
                                        </td>

                                        <!-- Situação -->
                                        <td>
                                            <span t-att-class="'badge ' + stateBadge(rec.state)"
                                                  t-esc="stateLabel(rec.state)"/>
                                        </td>

                                        <!-- Desvio -->
                                        <td class="text-center">
                                            <t t-if="rec.has_deviation">
                                                <span class="text-warning"
                                                      style="cursor:pointer;font-size:14px;"
                                                      t-att-title="rec.deviation_notes or 'Desvio registrado'"
                                                      t-on-click="() => this.onDeviation(rec.id)">⚠</span>
                                            </t>
                                            <t t-else="">
                                                <span class="text-muted"
                                                      style="cursor:pointer;font-size:14px;"
                                                      title="Sem desvio"
                                                      t-on-click="() => this.onDeviation(rec.id)">○</span>
                                            </t>
                                        </td>

                                        <!-- Botões de ação -->
                                        <td class="o_repair_proc_actions">
                                            <t t-if="state.loadingId === rec.id">
                                                <i class="fa fa-spinner fa-spin text-muted"/>
                                            </t>
                                            <t t-else="">

                                                <t t-if="rec.state === 'ready' or rec.state === 'paused'">
                                                    <button class="o_repair_action_btn btn-success"
                                                            t-on-click="() => this.onStart(rec.id)">
                                                        Iniciar
                                                    </button>
                                                </t>

                                                <t t-if="rec.state === 'progress'">
                                                    <button class="o_repair_action_btn btn-warning"
                                                            t-on-click="() => this.onPause(rec.id)">
                                                        Pausar
                                                    </button>
                                                </t>

                                                <t t-if="rec.state === 'progress' or rec.state === 'paused'">
                                                    <button class="o_repair_action_btn o_repair_btn_concluir"
                                                            t-on-click="() => this.onFinish(rec.id)">
                                                        Concluir
                                                    </button>
                                                </t>

                                                <t t-if="rec.state === 'ready' or rec.state === 'paused'">
                                                    <button class="o_repair_action_btn btn-secondary ms-1"
                                                            t-on-click="() => this.onCancel(rec.id)">
                                                        Cancelar
                                                    </button>
                                                </t>

                                                <t t-if="rec.state === 'ready' or rec.state === 'cancel'">
                                                    <button class="btn btn-sm btn-link text-danger p-0 ms-2"
                                                            title="Excluir processo"
                                                            t-on-click="() => this.onDelete(rec.id)">
                                                        <i class="fa fa-trash"/>
                                                    </button>
                                                </t>

                                            </t>
                                        </td>

                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>

            </t>
        </div>

    </t>
</div>
</t>

</templates>
