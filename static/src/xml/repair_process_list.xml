<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="cylinder_repair_os.RepairProcessList" owl="1">
    <div class="o_repair_process_widget">
        <table class="o_repair_proc_table table table-sm mb-0">
            <thead class="o_repair_proc_thead">
                <tr>
                    <th style="width:50px">Seq.</th>
                    <th>Operação</th>
                    <th style="width:140px">Máquina</th>
                    <th style="width:110px">Data Prog.</th>
                    <th style="width:150px">Dt. Início</th>
                    <th style="width:90px">Tempo</th>
                    <th style="width:110px">Situação</th>
                    <th style="width:40px">⚠</th>
                    <th style="width:210px"></th>
                </tr>
            </thead>
            <tbody>
                <t t-if="grouped.length === 0">
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            Nenhum processo. Use <strong>Carregar Processos</strong>.
                        </td>
                    </tr>
                </t>
                <t t-foreach="grouped" t-as="group" t-key="group.id">
                    <!-- Cabeçalho do grupo -->
                    <tr class="o_repair_group_header" t-on-click="() => this.toggle(group.id)">
                        <td colspan="9">
                            <span class="o_repair_group_arrow">
                                <t t-if="collapsed[group.id]">▶</t>
                                <t t-else="">▼</t>
                            </span>
                            <strong class="o_repair_group_name" t-esc="group.name"/>
                            <span class="badge bg-secondary ms-2" t-esc="group.records.length + ' processo(s)'"/>
                            <t t-if="group.prog > 0">
                                <span class="badge o_repair_badge_progress ms-1">
                                    <t t-esc="group.prog"/> em andamento
                                </span>
                            </t>
                            <t t-if="group.done === group.records.length and group.records.length > 0">
                                <span class="badge bg-success ms-1">Concluído</span>
                            </t>
                        </td>
                    </tr>
                    <!-- Linhas do grupo -->
                    <t t-if="!collapsed[group.id]">
                        <t t-foreach="group.records" t-as="rec" t-key="rec.id">
                            <tr t-att-class="rowCls(rec.data.state)">
                                <td class="text-center o_repair_proc_seq"><t t-esc="rec.data.sequence"/></td>
                                <td class="o_repair_proc_op"><t t-esc="rec.data.name"/></td>
                                <td class="o_repair_proc_machine">
                                    <t t-esc="rec.data.machine_id ? rec.data.machine_id[1] : '—'"/>
                                </td>
                                <td class="o_repair_proc_date">
                                    <t t-if="editDate.id === rec.id">
                                        <input type="date"
                                               class="form-control form-control-sm o_repair_date_input"
                                               t-att-value="rec.data.date_planned or ''"
                                               t-on-change="(ev) => this.saveDate(rec.id, ev)"
                                               t-on-blur="() => this.cancelEdit()"/>
                                    </t>
                                    <t t-else="">
                                        <span class="o_repair_date_display"
                                              t-on-click="() => this.startEdit(rec.id)"
                                              t-att-class="!rec.data.date_planned ? 'text-muted' : ''">
                                            <t t-if="rec.data.date_planned">
                                                <t t-esc="fmtDate(rec.data.date_planned)"/>
                                            </t>
                                            <t t-else="">definir</t>
                                        </span>
                                    </t>
                                </td>
                                <td class="o_repair_proc_date_start">
                                    <t t-esc="fmtDatetime(rec.data.date_start_orig)"/>
                                </td>
                                <td class="o_repair_proc_time">
                                    <span class="o_repair_timer"
                                          t-att-class="rec.data.state === 'progress' ? 'o_repair_timer_running' : ''"
                                          t-att-data-start="rec.data.date_start or ''"
                                          t-att-data-acc="rec.data.duration_acc or 0">
                                        <t t-esc="rec.data.duration_display or '00:00:00'"/>
                                    </span>
                                </td>
                                <td>
                                    <span t-att-class="stateCls(rec.data.state)"
                                          t-esc="stateLabel(rec.data.state)"/>
                                </td>
                                <td class="text-center">
                                    <t t-if="rec.data.has_deviation">
                                        <span class="o_repair_deviation_alert"
                                              t-att-title="rec.data.deviation_tooltip or 'Desvio registrado'"
                                              t-on-click="() => this.onDeviation(rec.id)"
                                              style="cursor:pointer">⚠</span>
                                    </t>
                                    <t t-else="">
                                        <span style="cursor:pointer;color:#d1d5db"
                                              t-on-click="() => this.onDeviation(rec.id)"
                                              title="Sem desvio">○</span>
                                    </t>
                                </td>
                                <td class="o_repair_proc_actions">
                                    <t t-if="loadingId.val === rec.id">
                                        <i class="fa fa-spinner fa-spin text-muted"/>
                                    </t>
                                    <t t-else="">
                                        <t t-if="rec.data.state === 'ready' or rec.data.state === 'paused'">
                                            <button class="btn btn-sm btn-success o_repair_action_btn"
                                                    t-on-click="() => this.onStart(rec.id)">Iniciar</button>
                                        </t>
                                        <t t-if="rec.data.state === 'progress'">
                                            <button class="btn btn-sm btn-warning o_repair_action_btn"
                                                    t-on-click="() => this.onPause(rec.id)">Pausar</button>
                                        </t>
                                        <t t-if="rec.data.state === 'progress' or rec.data.state === 'paused'">
                                            <button class="btn btn-sm o_repair_btn_concluir o_repair_action_btn"
                                                    t-on-click="() => this.onFinish(rec.id)">Concluir</button>
                                        </t>
                                        <t t-if="rec.data.state === 'ready' or rec.data.state === 'paused'">
                                            <button class="btn btn-sm btn-link text-danger o_repair_action_btn"
                                                    t-on-click="() => this.onCancel(rec.id)"
                                                    title="Cancelar"><i class="fa fa-ban"/></button>
                                        </t>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </t>
                </t>
            </tbody>
        </table>
    </div>
</t>

</templates>
