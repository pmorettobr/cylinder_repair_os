<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ Kanban de OS ═══════════════════════════════════════════════════ -->
    <record id="view_repair_dashboard_kanban" model="ir.ui.view">
        <field name="name">repair.dashboard.kanban</field>
        <field name="model">repair.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="os_state"
                    class="o_repair_kanban"
                    quick_create="0"
                    group_create="0"
                    group_delete="0"
                    group_fold="0">

                <field name="os_number"/>
                <field name="order_type"/>
                <field name="partner_id"/>
                <field name="product_name"/>
                <field name="responsible_id"/>
                <field name="deadline_date"/>
                <field name="os_state"/>
                <field name="is_overdue"/>
                <field name="progress_percent"/>
                <field name="process_count"/>
                <field name="process_done_count"/>

                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="o_kanban_card o_repair_card #{record.is_overdue.raw_value ? 'o_repair_overdue' : ''}">

                            <!-- Header: tipo + prazo -->
                            <div class="o_repair_card_header">
                                <div class="o_repair_card_badges">
                                    <span t-if="record.order_type.raw_value == 'repair'"
                                          class="badge o_repair_badge_reparo">Reparo</span>
                                    <span t-if="record.order_type.raw_value == 'fabrication'"
                                          class="badge o_repair_badge_fabricacao">Fabricação</span>
                                </div>
                                <div t-if="record.deadline_date.raw_value"
                                     t-attf-class="o_repair_deadline #{record.is_overdue.raw_value ? 'text-danger fw-bold' : ''}">
                                    <i class="fa fa-calendar-o me-1"/>
                                    <t t-esc="record.deadline_date.value"/>
                                </div>
                            </div>

                            <!-- Nº OS -->
                            <div class="o_repair_card_title">
                                <span class="o_repair_os_number">
                                    <t t-esc="record.os_number.value"/>
                                </span>
                            </div>

                            <!-- Cliente / Produto / Responsável -->
                            <div class="o_repair_card_info">
                                <div t-if="record.partner_id.value">
                                    <i class="fa fa-user text-muted me-1"/>
                                    <t t-esc="record.partner_id.value"/>
                                </div>
                                <div t-if="record.product_name.value">
                                    <i class="fa fa-cog text-muted me-1"/>
                                    <t t-esc="record.product_name.value"/>
                                </div>
                                <div t-if="record.responsible_id.value">
                                    <i class="fa fa-user-circle text-muted me-1"/>
                                    <span class="text-muted">
                                        <t t-esc="record.responsible_id.value"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Barra de progresso degradê -->
                            <div class="o_repair_card_progress">
                                <div class="o_repair_progress_bar_wrap">
                                    <div class="o_repair_progress_bar_fill"
                                         t-attf-style="width: #{record.progress_percent.raw_value or 0}%"/>
                                </div>
                                <div class="o_repair_progress_stats">
                                    <span class="text-muted" style="font-size:11px">
                                        <t t-esc="record.process_done_count.value"/>/<t t-esc="record.process_count.value"/> processos
                                    </span>
                                    <span t-attf-class="o_repair_pct #{(record.progress_percent.raw_value or 0) == 100 ? 'text-success fw-bold' : 'text-primary'}">
                                        <t t-esc="Math.round(record.progress_percent.raw_value or 0)"/>%
                                    </span>
                                </div>
                            </div>

                            <!-- Rodapé -->
                            <div class="o_repair_card_footer">
                                <a type="open" class="btn btn-sm o_repair_btn_open">
                                    Ver OS <i class="fa fa-arrow-right ms-1"/>
                                </a>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══ Action Dashboard ═══════════════════════════════════════════════ -->
    <record id="action_repair_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard — Ordens de Serviço</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'kanban',
                  'view_id':ref('cylinder_repair_os.view_repair_dashboard_kanban')}),
            (0,0,{'view_mode':'tree',
                  'view_id':ref('cylinder_repair_os.view_repair_order_os_tree')}),
            (0,0,{'view_mode':'form',
                  'view_id':ref('cylinder_repair_os.view_repair_order_os_form')})]"/>
        <field name="search_view_id" ref="cylinder_repair_os.view_repair_order_os_search"/>
        <field name="domain">[('os_state','not in',['cancel','done'])]</field>
        <field name="context">{'search_default_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Nenhuma ordem de serviço ativa
            </p>
            <p>Clique em <strong>Novo</strong> para criar a primeira OS.</p>
        </field>
    </record>

</odoo>
