<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_repair_machine_report_wizard" model="ir.ui.view">
        <field name="name">repair.machine.report.wizard.form</field>
        <field name="model">repair.machine.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Relatórios de OS">
                <sheet>

                    <!-- Seção 1: Programação por Máquina -->
                    <div class="mb-3">
                        <h4 style="color:#4f46e5;margin-bottom:4px;">
                            <i class="fa fa-industry me-2"/>Programação por Máquina
                        </h4>
                        <p class="text-muted" style="font-size:12px;margin:0;">
                            Gera a ordem de produção agrupada por OS. Impresso em paisagem.
                        </p>
                    </div>

                    <group string="Estado dos Processos">
                        <group>
                            <field name="state_ready"      string="Pronto"/>
                            <field name="state_progress"   string="Em Andamento"/>
                            <field name="state_paused"     string="Pausado"/>
                        </group>
                        <group>
                            <field name="state_pending_cq" string="Aguardando CQ"/>
                            <field name="state_done"       string="Concluído"/>
                            <field name="state_cancel"     string="Cancelado"/>
                        </group>
                    </group>

                    <group string="Filtros Opcionais">
                        <field name="machine_id" placeholder="Todas as máquinas"
                               string="Máquina" options="{'no_open': True}"/>
                        <field name="os_id" placeholder="Todas as OS"
                               string="Nº OS" options="{'no_open': True}"/>
                        <field name="use_date_filter" string="Filtrar por período?"/>
                        <field name="date_from" string="De"
                               attrs="{'invisible': [('use_date_filter','=',False)],
                                       'required':  [('use_date_filter','=',True)]}"/>
                        <field name="date_to" string="Até"
                               attrs="{'invisible': [('use_date_filter','=',False)],
                                       'required':  [('use_date_filter','=',True)]}"/>
                    </group>

                    <div class="mt-1 mb-4 d-flex gap-2">
                        <button name="action_print_report"
                                string="Gerar Programação (PDF)"
                                type="object"
                                class="btn btn-primary"/>
                        <button name="action_export_xls"
                                string="Exportar XLS"
                                type="object"
                                class="btn btn-outline-secondary"/>
                    </div>

                    <hr/>

                    <!-- Seção 2: Impressão de OS Completa -->
                    <div class="mb-3 mt-3">
                        <h4 style="color:#059669;margin-bottom:4px;">
                            <i class="fa fa-file-text me-2"/>Impressão de OS Completa
                        </h4>
                        <p class="text-muted" style="font-size:12px;margin:0;">
                            Imprime todos os processos da OS selecionada, concluídos ou não.
                        </p>
                    </div>
                    <group>
                        <field name="os_id_print" string="Nº OS"
                               placeholder="Selecione a OS..."
                               options="{'no_open': True}"/>
                    </group>
                    <div class="mt-1">
                        <button name="action_print_os"
                                string="Imprimir OS Completa (PDF)"
                                type="object"
                                class="btn btn-success"/>
                    </div>

                </sheet>
                <footer>
                    <button string="Fechar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_repair_machine_report_wizard" model="ir.actions.act_window">
        <field name="name">Relatórios</field>
        <field name="res_model">repair.machine.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
