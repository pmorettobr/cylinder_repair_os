<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_repair_machine_report_wizard" model="ir.ui.view">
        <field name="name">repair.machine.report.wizard.form</field>
        <field name="model">repair.machine.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Relatórios de OS">
                <sheet>

                    <!-- Secao 1: Programacao por Maquina -->
                    <div class="mb-3">
                        <h4 style="color:#4f46e5;margin-bottom:4px;">
                            <i class="fa fa-industry me-2"/>Programação por Máquina
                        </h4>
                        <p class="text-muted" style="font-size:12px;margin:0;">
                            Processos com Data Programada ou Data de Início dentro do período.
                            Impresso em paisagem. OS é opcional — filtra só processos daquela OS.
                        </p>
                    </div>

                    <group>
                        <group string="Período">
                            <field name="date_from"
                                   string="De"
                                   widget="date"
                                   required="1"/>
                            <field name="date_to"
                                   string="Até"
                                   widget="date"
                                   required="1"/>
                        </group>
                        <group string="Filtros Opcionais">
                            <field name="machine_id"
                                   string="Máquina"
                                   placeholder="Todas as máquinas"/>
                            <field name="os_id"
                                   string="Nº OS"
                                   placeholder="Todas as OS"
                                   domain="[('os_state', 'not in', ['cancel'])]"/>
                            <field name="include_done"
                                   string="Incluir Concluídos?"/>
                        </group>
                    </group>

                    <div class="mt-1 mb-4">
                        <button name="action_print_report"
                                string="Gerar Programação por Máquina (PDF)"
                                type="object"
                                class="btn btn-primary"/>
                    </div>

                    <hr/>

                    <!-- Secao 2: Impressao da OS completa -->
                    <div class="mb-3 mt-3">
                        <h4 style="color:#059669;margin-bottom:4px;">
                            <i class="fa fa-file-text me-2"/>Impressão de OS Completa
                        </h4>
                        <p class="text-muted" style="font-size:12px;margin:0;">
                            Imprime todos os processos da OS selecionada acima,
                            concluídos ou não. Data e Máquina são ignorados.
                        </p>
                    </div>

                    <div class="mt-1">
                        <button name="action_print_os"
                                string="Imprimir OS Completa (PDF)"
                                type="object"
                                class="btn btn-success"/>
                        <span class="text-muted ms-3" style="font-size:12px;">
                            Selecione o Nº OS no campo acima antes de imprimir.
                        </span>
                    </div>

                </sheet>
                <footer>
                    <button string="Fechar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_repair_machine_report_wizard" model="ir.actions.act_window">
        <field name="name">Relatórios</field>
        <field name="res_model">repair.machine.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
