<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE — somente Componente, Operação, Máquina -->
    <record id="view_repair_process_template_tree" model="ir.ui.view">
        <field name="name">repair.process.template.tree</field>
        <field name="model">repair.process.template</field>
        <field name="arch" type="xml">
            <tree string="Catálogo de Processos"
                  default_order="component_type_id, sequence">
                <field name="sequence" widget="handle"/>
                <field name="component_type_id" string="Componente" required="1"/>
                <field name="name" string="Operação" required="1"/>
                <field name="machine_id" string="Máquina"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_repair_process_template_form" model="ir.ui.view">
        <field name="name">repair.process.template.form</field>
        <field name="model">repair.process.template</field>
        <field name="arch" type="xml">
            <form string="Processo Padrão">
                <sheet>
                    <group>
                        <group string="Classificação">
                            <field name="duration_planned" string="Tempo Previsto (min)"
                                   help="Tempo padrão em minutos. Copiado para a OS ao carregar."/>
                            <field name="component_type_id" string="Componente" required="1"/>
                            <field name="name" string="Operação" required="1"/>
                            <field name="machine_id" string="Máquina Padrão"/>
                            <field name="sequence" string="Ordem de Execução"/>
                            <field name="active"/>
                        </group>
                        <group string="Qualidade">
                            <field name="quality_template_id" string="Template de QC"/>
                            <field name="block_on_quality_fail" string="Bloquear se Reprovar?"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_repair_process_template_search" model="ir.ui.view">
        <field name="name">repair.process.template.search</field>
        <field name="model">repair.process.template</field>
        <field name="arch" type="xml">
            <search string="Buscar Processos">
                <field name="name" string="Operação"/>
                <field name="component_type_id" string="Componente"/>
                <field name="machine_id" string="Máquina"/>
                <group expand="1" string="Agrupar por">
                    <filter name="group_component" string="Componente"
                            context="{'group_by': 'component_type_id'}"/>
                    <filter name="group_machine" string="Máquina"
                            context="{'group_by': 'machine_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_repair_process_template" model="ir.actions.act_window">
        <field name="name">Catálogo de Processos</field>
        <field name="res_model">repair.process.template</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_repair_process_template_search"/>
        <field name="context">{'search_default_group_component': 1}</field>
    </record>

</odoo>
