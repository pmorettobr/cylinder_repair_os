<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_repair_process_set_wizard_form" model="ir.ui.view">
        <field name="name">repair.process.set.wizard.form</field>
        <field name="model">repair.process.set.wizard</field>
        <field name="arch" type="xml">
            <form string="Adicionar Processos ao Template">
                <sheet>
                    <div class="o_repair_wizard_header mb-3">
                        <p class="text-muted">
                            Selecione os processos do catálogo para adicionar ao template
                            <strong><field name="set_id" readonly="1" class="d-inline"/></strong>.
                        </p>
                    </div>

                    <div class="mb-2 d-flex gap-2 align-items-center flex-wrap">
                        <button name="action_select_all" type="object"
                                string="✓ Todos" class="btn btn-sm btn-outline-primary"/>
                        <button name="action_deselect_all" type="object"
                                string="✗ Nenhum" class="btn btn-sm btn-outline-secondary"/>
                        <div class="ms-2 d-flex gap-1 flex-grow-1" style="max-width:360px;">
                            <field name="search_term"
                                   nolabel="1"
                                   placeholder="Componente ou operação..."
                                   style="flex:1;"/>
                            <button name="action_search" type="object"
                                    icon="fa-search"
                                    class="btn btn-sm btn-primary"
                                    title="Buscar"/>
                        </div>
                    </div>

                    <field name="line_ids" nolabel="1">
                        <tree editable="bottom" create="0" delete="0"
                              default_order="component_type_id, sequence"
                              decoration-success="selected == True">
                            <field name="selected" string="✓" widget="boolean_toggle"/>
                            <field name="component_type_id" string="Componente" readonly="1"/>
                            <field name="template_id" string="Operação" readonly="1"/>
                            <field name="machine_id" string="Centro de Trabalho" readonly="1"/>
                            <field name="sequence" string="Seq." readonly="1" optional="hide"/>
                            <field name="requires_cq" string="CQ?" readonly="1" optional="show"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Adicionar Selecionados" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
