<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ TREE ═══════════════════════════════════════════════════════════ -->
    <record id="view_repair_order_os_tree" model="ir.ui.view">
        <field name="name">repair.order.os.tree</field>
        <field name="model">repair.order</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree string="Ordens de Serviço"
                  decoration-success="os_state == 'done'"
                  decoration-warning="os_state == 'in_progress'"
                  decoration-muted="os_state == 'cancel'"
                  decoration-danger="is_overdue">
                <field name="os_number" string="Nº OS"/>
                <field name="order_type" string="Tipo" widget="badge"
                       decoration-info="order_type == 'repair'"
                       decoration-warning="order_type == 'fabrication'"/>
                <field name="partner_id" string="Cliente"/>
                <field name="product_name" string="Produto / Cilindro"/>
                <field name="responsible_id" string="Responsável"/>
                <field name="deadline_date" string="Prazo"/>
                <field name="os_state" string="Estado" widget="badge"
                       decoration-success="os_state == 'done'"
                       decoration-warning="os_state in ('in_progress','confirmed')"
                       decoration-muted="os_state in ('cancel','draft')"/>
                <field name="process_done_display" string="Concluídos" readonly="1"/>
                <field name="process_total_display" string="Total" readonly="1"/>
                <field name="progress_display" string="Progresso" readonly="1"/>
                <field name="is_overdue" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ══ FORM ═══════════════════════════════════════════════════════════ -->
    <record id="view_repair_order_os_form" model="ir.ui.view">
        <field name="name">repair.order.os.form</field>
        <field name="model">repair.order</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Ordem de Serviço" class="o_repair_form">

                <header>
                    <field name="os_state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,done"/>
                    <button name="action_confirm_os" string="Confirmar"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('os_state', '!=', 'draft')]}"/>
                    <button name="action_start_os" string="Iniciar OS"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('os_state', '!=', 'confirmed')]}"/>
                    <button name="action_done_os" string="Concluir OS"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('os_state', '!=', 'in_progress')]}"/>
                    <button name="action_draft_os" string="Reabrir"
                            type="object" class="btn-secondary"
                            attrs="{'invisible': [('os_state', '!=', 'confirmed')]}"/>
                    <button name="action_cancel_os" string="Cancelar"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('os_state', 'in', ('done', 'cancel'))]}"/>
                </header>

                <sheet>
                    <!-- Campos nativos invisíveis necessários -->
                    <field name="state" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="is_overdue" invisible="1"/>
                    <field name="progress_percent" invisible="1"
                           class="o_repair_progress_value"/>

                    <!-- ── Título: Nº OS grande + Tipo colorido ─────── -->
                    <div class="o_repair_form_title">
                        <div class="o_repair_title_row">
                            <div class="o_repair_os_number_big">
                                <label for="os_number" class="o_repair_os_label">Nº OS</label>
                                <field name="os_number"
                                       class="o_repair_os_input"
                                       placeholder="Nº da OS do cliente..."
                                       attrs="{'readonly': [('os_state', 'not in', ('draft',))]}"/>
                            </div>
                            <div class="o_repair_type_selector">
                                <field name="order_type"
                                       widget="radio"
                                       class="o_repair_type_radio"/>
                            </div>
                            <div class="o_repair_overdue_badge"
                                 attrs="{'invisible': [('is_overdue', '=', False)]}">
                                <span class="badge bg-danger">⚠ Atrasada</span>
                            </div>
                        </div>
                    </div>

                    <!-- ── Dados da OS ────────────────────────────────── -->
                    <group class="o_repair_header_fields">
                        <group string="Identificação">
                            <field name="partner_id" string="Cliente" required="1"/>
                            <field name="product_name" string="Produto / Cilindro"
                                   placeholder="Ex: Cilindro Hidráulico CH-1..."/>
                            <field name="responsible_id" string="Responsável"/>
                        </group>
                        <group string="Prazo e Progresso">
                            <field name="deadline_date" string="Prazo (Dead Line)"
                                   widget="date"/>
                            <field name="process_count" string="Total"/>
                            <field name="process_done_count" string="Concluídos"/>
                            <field name="process_progress_count" string="Em Andamento"/>
                        </group>
                    </group>

                    <!-- ── Barra de Progresso ─────────────────────────── -->
                    <div class="o_repair_progress_strip">
                        <div class="o_repair_progress_bar_wrap">
                            <div class="o_repair_progress_bar_fill o_repair_progress_fill_dynamic"/>
                        </div>
                        <span class="o_repair_progress_pct">
                            <field name="progress_display" readonly="1"/>
                        </span>
                    </div>

                    <!-- ── Processos ──────────────────────────────────── -->
                    <div class="o_repair_processes_header">
                        <h4 class="o_repair_section_title">Processos</h4>
                        <button name="action_open_process_loader"
                                string="⚙ Carregar Processos"
                                type="object"
                                class="btn-sm btn-outline-primary o_repair_load_btn"
                                attrs="{'invisible': [('os_state', 'in', ('done', 'cancel'))]}"/>
                    </div>

                    <field name="process_ids"
                           context="{'default_repair_id': id}">
                        <tree string="Processos"
                              decoration-success="state == 'done'"
                              decoration-warning="state == 'progress'"
                              decoration-info="state == 'paused'"
                              decoration-muted="state in ('ready', 'cancel')"
                              editable="bottom"
                              create="0"
                              default_order="component_type_id, sequence">

                            <field name="state" invisible="1"/>
                            <field name="has_deviation" invisible="1"/>

                            <!-- Seq -->
                            <field name="sequence" string="Seq." readonly="1" width="40"/>

                            <!-- Componente -->
                            <field name="component_type_id" string="Componente" readonly="1"/>

                            <!-- Operação -->
                            <field name="name" string="Operação" readonly="1"/>

                            <!-- Máquina — só nome -->
                            <field name="machine_id" string="Máquina" readonly="1"/>

                            <!-- Data Programada com datepicker OCA -->
                            <field name="date_planned" string="Data Prog."
                                   widget="date"
                                   optional="show"/>

                            <!-- Data Início real -->
                            <field name="date_start_orig" string="Dt. Início"
                                   readonly="1" optional="show"/>

                            <!-- Cronômetro -->
                            <field name="duration_display" string="Tempo"
                                   readonly="1"
                                   class="o_repair_timer"/>

                            <!-- Situação -->
                            <field name="state" string="Situação" widget="badge"
                                   decoration-success="state == 'done'"
                                   decoration-warning="state == 'progress'"
                                   decoration-info="state == 'paused'"
                                   decoration-muted="state in ('ready', 'cancel')"
                                   readonly="1"/>

                            <!-- Coluna Desvio — ícone ⚠ ou ○ -->
                            <field name="deviation_icon" string="Desvio"
                                   readonly="1"
                                   class="o_repair_deviation_icon"
                                   decoration-warning="has_deviation == True"
                                   decoration-muted="has_deviation == False"/>

                            <!-- Botão Iniciar -->
                            <button name="action_start" type="object"
                                    string="Iniciar" class="btn-sm btn-success"
                                    attrs="{'invisible': [('state', 'not in', ['ready', 'paused'])]}"/>

                            <!-- Botão Pausar -->
                            <button name="action_pause" type="object"
                                    string="Pausar" class="btn-sm btn-warning"
                                    attrs="{'invisible': [('state', '!=', 'progress')]}"/>

                            <!-- Botão Concluir -->
                            <button name="action_finish" type="object"
                                    string="Concluir" class="btn-sm btn-primary"
                                    attrs="{'invisible': [('state', 'not in', ['progress', 'paused'])]}"/>

                            <!-- Botão Excluir (lixeira) — única lixeira -->
                            <button name="action_cancel" type="object"
                                    icon="fa-trash"
                                    class="btn-sm btn-link text-danger"
                                    title="Excluir processo"
                                    attrs="{'invisible': [('state', 'in', ('progress',))]}"/>

                        </tree>
                    </field>

                </sheet>

            </form>
        </field>
    </record>

    <!-- ══ SEARCH ═════════════════════════════════════════════════════════ -->
    <record id="view_repair_order_os_search" model="ir.ui.view">
        <field name="name">repair.order.os.search</field>
        <field name="model">repair.order</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <search string="Buscar OS">
                <field name="os_number" string="Nº OS"/>
                <field name="partner_id" string="Cliente"/>
                <field name="product_name" string="Produto / Cilindro"/>
                <field name="responsible_id" string="Responsável"/>
                <separator/>
                <filter name="repair" string="Reparo"
                        domain="[('order_type','=','repair')]"/>
                <filter name="fabrication" string="Fabricação"
                        domain="[('order_type','=','fabrication')]"/>
                <separator/>
                <filter name="draft" string="Rascunho"
                        domain="[('os_state','=','draft')]"/>
                <filter name="confirmed" string="Confirmada"
                        domain="[('os_state','=','confirmed')]"/>
                <filter name="in_progress" string="Em Andamento"
                        domain="[('os_state','=','in_progress')]"/>
                <filter name="done" string="Concluída"
                        domain="[('os_state','=','done')]"/>
                <separator/>
                <filter name="overdue" string="Atrasadas"
                        domain="[('is_overdue','=',True)]"/>
                <group expand="1" string="Agrupar por">
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'os_state'}"/>
                    <filter name="group_type" string="Tipo de Ordem"
                            context="{'group_by': 'order_type'}"/>
                    <filter name="group_partner" string="Cliente"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_responsible" string="Responsável"
                            context="{'group_by': 'responsible_id'}"/>
                    <filter name="group_deadline" string="Prazo"
                            context="{'group_by': 'deadline_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══ ACTIONS ════════════════════════════════════════════════════════ -->
    <record id="action_repair_orders_os" model="ir.actions.act_window">
        <field name="name">Ordens de Serviço</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'tree','view_id':ref('cylinder_repair_os.view_repair_order_os_tree')}),
            (0,0,{'view_mode':'form','view_id':ref('cylinder_repair_os.view_repair_order_os_form')})]"/>
        <field name="search_view_id" ref="view_repair_order_os_search"/>
        <field name="context">{'search_default_in_progress': 1}</field>
    </record>

    <record id="action_repair_orders_repair" model="ir.actions.act_window">
        <field name="name">Reparos</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'tree','view_id':ref('cylinder_repair_os.view_repair_order_os_tree')}),
            (0,0,{'view_mode':'form','view_id':ref('cylinder_repair_os.view_repair_order_os_form')})]"/>
        <field name="search_view_id" ref="view_repair_order_os_search"/>
        <field name="domain">[('order_type', '=', 'repair')]</field>
        <field name="context">{'default_order_type': 'repair'}</field>
    </record>

    <record id="action_repair_orders_fabrication" model="ir.actions.act_window">
        <field name="name">Fabricações</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'tree','view_id':ref('cylinder_repair_os.view_repair_order_os_tree')}),
            (0,0,{'view_mode':'form','view_id':ref('cylinder_repair_os.view_repair_order_os_form')})]"/>
        <field name="search_view_id" ref="view_repair_order_os_search"/>
        <field name="domain">[('order_type', '=', 'fabrication')]</field>
        <field name="context">{'default_order_type': 'fabrication'}</field>
    </record>

</odoo>
