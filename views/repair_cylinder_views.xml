<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_repair_cylinder_tree" model="ir.ui.view">
        <field name="name">repair.cylinder.tree</field>
        <field name="model">repair.cylinder</field>
        <field name="arch" type="xml">
            <tree string="Cilindros">
                <field name="code" string="Código"/>
                <field name="name" string="Descrição"/>
                <field name="process_set_id" string="Template"/>
                <field name="os_count" string="OSs"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_repair_cylinder_form" model="ir.ui.view">
        <field name="name">repair.cylinder.form</field>
        <field name="model">repair.cylinder</field>
        <field name="arch" type="xml">
            <form string="Cilindro">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Cilindro"/>
                        <h1><field name="name" placeholder="Descrição do cilindro..."/></h1>
                    </div>
                    <group>
                        <group string="Identificação">
                            <field name="code" string="Código"/>
                            <field name="active" string="Ativo"/>
                        </group>
                        <group string="Template de Processos">
                            <field name="process_set_id"
                                   string="Template Padrão"
                                   options="{'no_create': False}"
                                   help="Ao selecionar este cilindro numa OS, este template é carregado automaticamente."/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" string="Observações" placeholder="Observações adicionais..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_repair_cylinder_search" model="ir.ui.view">
        <field name="name">repair.cylinder.search</field>
        <field name="model">repair.cylinder</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Descrição"/>
                <field name="code" string="Código"/>
            </search>
        </field>
    </record>

    <record id="action_repair_cylinders" model="ir.actions.act_window">
        <field name="name">Cilindros</field>
        <field name="res_model">repair.cylinder</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_repair_cylinder_search"/>
    </record>

</odoo>
