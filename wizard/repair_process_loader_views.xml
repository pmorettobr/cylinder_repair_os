<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_repair_process_loader_form" model="ir.ui.view">
        <field name="name">repair.process.loader.form</field>
        <field name="model">repair.process.loader</field>
        <field name="arch" type="xml">
            <form string="Carregar Processos em Lote">
                <sheet>
                    <div class="o_repair_wizard_header">
                        <h4>Carregar Processos do Catálogo</h4>
                        <p class="text-muted">
                            Selecione os processos para adicionar à OS
                            <strong><field name="repair_id" readonly="1" class="d-inline"/></strong>.
                        </p>
                    </div>

                    <!-- Alerta catálogo vazio -->
                    <div class="alert alert-warning"
                         attrs="{'invisible': [('catalog_empty', '=', False)]}">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        O catálogo está vazio. Acesse
                        <strong>Configuração → Catálogo de Processos</strong>
                        para cadastrar processos padrão.
                    </div>

                    <!-- Filtro por componente -->
                    <group>
                        <field name="filter_component_id"
                               string="Filtrar por Componente"
                               placeholder="Todos os componentes"/>
                    </group>

                    <!-- Botões Selecionar / Desselecionar -->
                    <div class="o_repair_loader_actions mb-2">
                        <button name="action_select_all" type="object"
                                string="✓ Selecionar Todos"
                                class="btn-sm btn-outline-primary me-2"/>
                        <button name="action_deselect_all" type="object"
                                string="✗ Desmarcar Todos"
                                class="btn-sm btn-outline-secondary"/>
                    </div>

                    <!-- Lista de processos -->
                    <field name="line_ids"
                           attrs="{'invisible': [('catalog_empty', '=', True)]}">
                        <tree editable="bottom"
                              decoration-muted="selected == False">
                            <field name="selected" string="✓" widget="boolean_toggle"/>
                            <field name="component_type_id" string="Componente"
                                   options="{'no_create': True}"/>
                            <field name="sub_component_id" string="Sub-comp."
                                   domain="[('component_type_id', 'in', [component_type_id, False])]"
                                   options="{'no_create': True}" optional="hide"/>
                            <field name="name" string="Operação"/>
                            <field name="machine_id" string="Máquina"
                                   options="{'no_create': True}"/>
                            <field name="quality_template_id" string="Template QC"
                                   optional="hide"/>
                            <field name="sequence" string="Ord." optional="show"/>
                        </tree>
                    </field>

                </sheet>
                <footer>
                    <button name="action_load_processes"
                            string="Carregar Processos Selecionados"
                            type="object"
                            class="btn-primary"
                            close="1"
                            attrs="{'invisible': [('catalog_empty', '=', True)]}"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
